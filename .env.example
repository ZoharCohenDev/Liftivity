# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (Docker Compose):
POSTGRES_PASSWORD=secret
DATABASE_URL=postgresql://liftivity:secret@localhost:5432/liftivity_dev
# For local dev, DIRECT_URL = DATABASE_URL (no pooler involved):
DIRECT_URL=postgresql://liftivity:secret@localhost:5432/liftivity_dev

# Supabase — replace all three vars:
#   POSTGRES_PASSWORD → your Supabase DB password
#   DATABASE_URL      → Transaction Pooler URL  (port 6543, add ?pgbouncer=true&connection_limit=1)
#   DIRECT_URL        → Direct connection URL   (port 5432, used by prisma migrate only)
# POSTGRES_PASSWORD=your_supabase_password
# DATABASE_URL=postgresql://postgres.[ref]:[pw]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# DIRECT_URL=postgresql://postgres.[ref]:[pw]@aws-0-[region].pooler.supabase.com:5432/postgres

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must be at least 32 characters and must not equal the example value.
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=REPLACE_THIS_WITH_A_STRONG_32_CHAR_SECRET_VALUE
JWT_EXPIRES_IN=7d

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=3000
API_BASE_URL=http://localhost:3000

# ── Web ───────────────────────────────────────────────────────────────────────
# Must match the exact origin of the frontend (no trailing slash).
WEB_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:3000

# ── Python services ───────────────────────────────────────────────────────────
NLP_SERVICE_URL=http://localhost:8001
CV_SERVICE_URL=http://localhost:8002
SCORING_SERVICE_URL=http://localhost:8003

# ── ML / AI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
HF_TOKEN=
