{
  "name": "@liftivity/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "dotenv -e ../.env -- ts-node-dev --respawn src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "lint": "eslint src --ext ts",
    "typecheck": "tsc --noEmit",
    "test": "echo 'No tests configured yet'",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "psql $DATABASE_URL -f ../infra/db/seeds/seed_dev.sql",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@fastify/cors": "^8.5.0",
    "@prisma/client": "^5.14.0",
    "fastify": "^4.27.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@liftivity/config": "workspace:*",
    "@liftivity/shared-types": "workspace:*",
    "@types/node": "^20.14.0",
    "dotenv-cli": "^11.0.0",
    "prisma": "^5.14.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
