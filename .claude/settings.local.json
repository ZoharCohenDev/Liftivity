{
  "permissions": {
    "allow": [
      "Bash(pnpm *)",
      "Bash(python3 -c ' *)",
      "Bash(python3 -m json.tool)"
    ]
  },
  "env": {
    "ANTHROPIC_BASE_URL": "https://openrouter.ai/api/v1",
    "ANTHROPIC_API_KEY": "$OPENROUTER_API_KEY",

    "ANTHROPIC_MODEL": "google/gemma-4-26b-a4b-it:free",
    
    "ANTHROPIC_CUSTOM_MODEL_OPTION": "nvidia/nemotron-3-super-120b-a12b:free",
    "ANTHROPIC_CUSTOM_MODEL_OPTION_NAME": "Nemotron Free",
    "ANTHROPIC_CUSTOM_MODEL_OPTION_DESCRIPTION": "Nvidia Nemotron 120B free model"
},
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Create",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/guard.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/pre-edit.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Create",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-edit.sh"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "postman": {
      "type": "url",
      "url": "https://mcp.postman.com/mcp/v1",
      "headers": {
        "x-api-key": "$POSTMAN_API_KEY"
      }
    }
  }
}
