{
  "permissions": {
    "allow": [
      "Bash(pnpm *)",
      "Bash(python3 -c ' *)",
      "Bash(python3 -m json.tool)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Create",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/guard.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/pre-edit.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Create",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-edit.sh"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "postman": {
      "type": "url",
      "url": "https://mcp.postman.com/mcp/v1",
      "headers": {
        "x-api-key": "$POSTMAN_API_KEY"
      }
    }
  }
}
